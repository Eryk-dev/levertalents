# Lever Talents Hub — variáveis de ambiente do frontend.
# Copie este arquivo para .env.local e preencha com as credenciais do seu
# projeto Supabase.

# URL do projeto Supabase (encontrável em Project Settings > API)
VITE_SUPABASE_URL=https://<project-id>.supabase.co

# Chave anon/publishable do projeto Supabase (Project Settings > API).
# É pública por design (RLS é o que protege os dados) — mesmo assim o
# arquivo .env.local NÃO deve ser commitado.
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>

# ID do projeto Supabase (opcional — usado por alguns helpers do frontend).
VITE_SUPABASE_PROJECT_ID=<project-id>

# -----------------------------------------------------------------------------
# Secrets de Edge Functions (definidos via `supabase secrets set`, NÃO aqui):
#   SUPABASE_SERVICE_ROLE_KEY  — usada por list-users e create-user
#   OPENAI_API_KEY             — usada por transcribe-audio
#   LOVABLE_API_KEY            — usada por summarize-meeting
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Deploy em VPS com Docker (docker-compose.yml).
# Estas vars são lidas em build time e injetadas no bundle Vite.
# -----------------------------------------------------------------------------

# Porta exposta pelo container na VPS (default: 8080 — troque se colidir).
HTTP_PORT=8080

# -----------------------------------------------------------------------------
# Sentry — observabilidade com scrubbing de PII (QUAL-06).
# Deixe vazio em dev para manter o Sentry desabilitado. Em produção, preencha
# com o DSN do projeto Sentry para começar a receber eventos.
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=
